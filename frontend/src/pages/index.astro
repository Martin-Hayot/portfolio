---
import HeroSection from "@/components/HeroSection";
import AboutSection from "@/components/AboutSection";
import LinkGrid from "@/components/LinkGrid";
import "@/styles/globals.css";
import Projects from "@/components/Projects";
import ContactSection from "@/components/ContactSection.astro";
import HomeLayout from "@/layouts/HomeLayout.astro";
---

<HomeLayout title={"Martin'space"}>
    <HeroSection client:load />

    <div class="pt-20" id="about">
        <AboutSection client:load />
    </div>

    <LinkGrid client:load />

    <Projects client:load />
    <ContactSection />

    <div class="w-full flex justify-center">
        <a
            download
            href="HAYOT_Martin_CV.pdf"
            class="bg-white mb-16 py-4 px-8 rounded-full shadow-lg text-lg font-bold text-neutral-900 hover:bg-violet-950 hover:text-white transition duration-300 ease-in-out"
            >Download <span class="font-bold">CV</span></a
        >
    </div>
</HomeLayout>


<style>
    @keyframes orbit-sm {
        from {
            transform: rotate(0deg) translateX(10em) rotate(0deg);
        }
        to {
            transform: rotate(360deg) translateX(10em) rotate(-360deg);
        }
    }

    @keyframes orbit-md {
        from {
            transform: rotate(0deg) translateX(12em) rotate(0deg);
        }
        to {
            transform: rotate(360deg) translateX(12em) rotate(-360deg);
        }
    }

    @keyframes orbit-lg {
        from {
            transform: rotate(0deg) translateX(15em) rotate(0deg);
        }
        to {
            transform: rotate(360deg) translateX(15em) rotate(-360deg);
        }
    }

    @keyframes orbit-xl {
        from {
            transform: rotate(0deg) translateX(20em) rotate(0deg);
        }
        to {
            transform: rotate(360deg) translateX(20em) rotate(-360deg);
        }
    }

    .animate-orbit-sm {
        animation: orbit-sm 30s linear infinite;
    }

    .animate-orbit-md {
        animation: orbit-md 30s linear infinite;
    }

    .animate-orbit-lg {
        animation: orbit-lg 30s linear infinite;
    }

    .animate-orbit-xl {
        animation: orbit-xl 30s linear infinite;
    }

    .animate-orbit:hover,
    .animate-orbit-sm:hover,
    .animate-orbit-md:hover,
    .animate-orbit-lg:hover,
    .animate-orbit-xl:hover {
        animation-play-state: paused;
    }
    .link-card-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
        padding: 0;
    }

    @keyframes push_401 {
        0%,
        50% {
            transform: translate(-50%, 0%) scale(1);
        }

        100% {
            transform: translate(-50%, -100%) scale(0.1);
        }
    }
</style>
