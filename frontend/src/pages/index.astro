---
import HeroSection from "@/components/HeroSection";
import AboutSection from "@/components/AboutSection";
import LinkGrid from "@/components/LinkGrid";
import "@/styles/globals.css";
import Projects from "@/components/Projects";
import HomeLayout from "@/layouts/HomeLayout.astro";
---

<HomeLayout title={"Martin'space"}>
    <HeroSection client:load />

    <div class="pt-20" id="about">
        <AboutSection client:load />
    </div>

    <LinkGrid client:load />

    <Projects client:load />
    <section
        class="relative z-10 w-[90%] mx-auto flex flex-col-reverse lg:flex-row justify-evenly items-center lg:-mt-10 mb-40"
    >
        <div>
            <div class="text-5xl font-bold text-gray-200 mt-16 md:mt-0"></div>

            <img
                src="/astro_talking2.jpg"
                alt="astro talking"
                decoding="async"
                loading="lazy"
                class="h-72 md:mt-6 lg:mt-0 xl:h-96"
                style="clip-path: polygon(0% 0%, 100% 0%, 100% 75%, 75% 75%, 75% 100%, 50% 75%, 0% 75%);"
            />
        </div>
        <div class="">
            <div
                class="w-full max-w-lg xl:max-w-2xl mt-20 lg:-mt-20 bg-neutral-900/70 border border-white/10 rounded-2xl shadow-xl shadow-black/30 p-7"
            >
                <p
                    class="text-xs font-semibold tracking-[0.18em] text-violet-300/80 mb-2"
                >
                    GET IN TOUCH
                </p>
                <h2 class="text-2xl font-semibold text-white mb-1">
                    Contact Me
                </h2>
                <p class="text-sm text-neutral-400 mb-6">
                    Have a project in mind or just want to say hi? Drop me a
                    message.
                </p>

                <form
                    method="POST"
                    action="https://formsubmit.co/mart.hyt2002@gmail.com"
                    class="flex flex-wrap gap-4"
                >
                    <input
                        type="hidden"
                        name="_next"
                        value="https://martinhayot.com/thanks"
                    />
                    <input
                        name="name"
                        type="text"
                        aria-label="Full name"
                        placeholder="Full Name"
                        class="w-full md:flex-1 bg-white/5 border border-white/10 rounded-lg px-4 py-2.5 text-sm text-neutral-100 placeholder:text-neutral-500 transition focus:border-violet-400/40 focus:outline-none focus:ring-2 focus:ring-violet-500/20"
                    />
                    <input
                        name="email"
                        type="email"
                        aria-label="Email"
                        placeholder="Email"
                        class="w-full md:flex-1 bg-white/5 border border-white/10 rounded-lg px-4 py-2.5 text-sm text-neutral-100 placeholder:text-neutral-500 transition focus:border-violet-400/40 focus:outline-none focus:ring-2 focus:ring-violet-500/20"
                    />
                    <textarea
                        name="message"
                        rows="4"
                        aria-label="Message"
                        placeholder="Message"
                        class="w-full resize-none bg-white/5 border border-white/10 rounded-lg px-4 py-2.5 text-sm text-neutral-100 placeholder:text-neutral-500 transition focus:border-violet-400/40 focus:outline-none focus:ring-2 focus:ring-violet-500/20"
                    ></textarea>

                    <button
                        type="submit"
                        class="mt-1 inline-flex items-center justify-center rounded-lg bg-primary px-6 py-2.5 text-sm font-semibold text-primary-foreground transition-colors hover:bg-primary/90"
                    >
                        Send message
                    </button>
                </form>
            </div>
        </div>
    </section>

    <div class="w-full flex justify-center">
        <a
            download
            href="HAYOT_Martin_CV.pdf"
            class="bg-white mb-16 py-4 px-8 rounded-full shadow-lg text-lg font-bold text-neutral-900 hover:bg-violet-950 hover:text-white transition duration-300 ease-in-out"
            >Download <span class="font-bold">CV</span></a
        >
    </div>
</HomeLayout>

<style>
    @keyframes orbit-sm {
        from {
            transform: rotate(0deg) translateX(10em) rotate(0deg);
        }
        to {
            transform: rotate(360deg) translateX(10em) rotate(-360deg);
        }
    }

    @keyframes orbit-md {
        from {
            transform: rotate(0deg) translateX(12em) rotate(0deg);
        }
        to {
            transform: rotate(360deg) translateX(12em) rotate(-360deg);
        }
    }

    @keyframes orbit-lg {
        from {
            transform: rotate(0deg) translateX(15em) rotate(0deg);
        }
        to {
            transform: rotate(360deg) translateX(15em) rotate(-360deg);
        }
    }

    @keyframes orbit-xl {
        from {
            transform: rotate(0deg) translateX(20em) rotate(0deg);
        }
        to {
            transform: rotate(360deg) translateX(20em) rotate(-360deg);
        }
    }

    .animate-orbit-sm {
        animation: orbit-sm 30s linear infinite;
    }

    .animate-orbit-md {
        animation: orbit-md 30s linear infinite;
    }

    .animate-orbit-lg {
        animation: orbit-lg 30s linear infinite;
    }

    .animate-orbit-xl {
        animation: orbit-xl 30s linear infinite;
    }

    .animate-orbit:hover,
    .animate-orbit-sm:hover,
    .animate-orbit-md:hover,
    .animate-orbit-lg:hover,
    .animate-orbit-xl:hover {
        animation-play-state: paused;
    }
    .link-card-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
        padding: 0;
    }

    @keyframes push_401 {
        0%,
        50% {
            transform: translate(-50%, 0%) scale(1);
        }

        100% {
            transform: translate(-50%, -100%) scale(0.1);
        }
    }
</style>
