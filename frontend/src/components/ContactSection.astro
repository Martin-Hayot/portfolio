<section
    id="contact"
    class="relative z-10 w-[90%] mx-auto flex flex-col-reverse lg:flex-row justify-evenly items-center lg:-mt-10 mb-40"
>
    <div>
        <div class="text-5xl font-bold text-gray-200 md:mt-0"></div>

        <img
            src="/astro_talking2.jpg"
            alt="astro talking"
            decoding="async"
            loading="lazy"
            class="h-72 mt-6 lg:mt-0 xl:h-96"
            style="clip-path: polygon(0% 0%, 100% 0%, 100% 75%, 75% 75%, 75% 100%, 50% 75%, 0% 75%);"
        />
    </div>
    <div>
        <div
            class="w-full max-w-lg xl:max-w-2xl mt-8 lg:-mt-20 bg-neutral-900/70 border border-white/10 rounded-2xl shadow-xl shadow-black/30 p-7"
        >
            <p
                class="text-xs font-semibold tracking-[0.18em] text-violet-300/80 mb-2"
            >
                GET IN TOUCH
            </p>
            <h2 class="text-2xl font-semibold text-white mb-1">Contact Me</h2>
            <p class="text-sm text-neutral-400 mb-6">
                Have a project in mind or just want to say hi? Drop me a
                message.
            </p>

            <form id="contact-form" class="flex flex-wrap gap-4">
                <div
                    aria-hidden="true"
                    style="position:absolute;left:-9999px;opacity:0;pointer-events:none;"
                >
                    <label
                        >Leave this empty <input
                            name="website"
                            type="text"
                            tabindex="-1"
                            autocomplete="off"
                        /></label
                    >
                </div>
                <input
                    name="name"
                    type="text"
                    aria-label="Full name"
                    placeholder="Full Name"
                    required
                    class="w-full md:flex-1 bg-white/5 border border-white/10 rounded-lg px-4 py-2.5 text-sm text-neutral-100 placeholder:text-neutral-500 transition focus:border-violet-400/40 focus:outline-none focus:ring-2 focus:ring-violet-500/20"
                />
                <input
                    name="email"
                    type="email"
                    aria-label="Email"
                    placeholder="Email"
                    required
                    class="w-full md:flex-1 bg-white/5 border border-white/10 rounded-lg px-4 py-2.5 text-sm text-neutral-100 placeholder:text-neutral-500 transition focus:border-violet-400/40 focus:outline-none focus:ring-2 focus:ring-violet-500/20"
                />
                <textarea
                    name="message"
                    rows="4"
                    aria-label="Message"
                    placeholder="Message"
                    required
                    class="w-full resize-none bg-white/5 border border-white/10 rounded-lg px-4 py-2.5 text-sm text-neutral-100 placeholder:text-neutral-500 transition focus:border-violet-400/40 focus:outline-none focus:ring-2 focus:ring-violet-500/20"
                ></textarea>

                <div class="w-full flex flex-col gap-2">
                    <button
                        id="submit-btn"
                        type="submit"
                        class="inline-flex items-center justify-center rounded-lg bg-primary px-6 py-2.5 text-sm font-semibold text-primary-foreground transition-colors hover:bg-primary/90 disabled:opacity-50 disabled:cursor-not-allowed"
                    >
                        Send message
                    </button>
                    <p id="form-status" class="text-sm"></p>
                </div>
            </form>
        </div>
    </div>
</section>

<script>
    const form = document.getElementById("contact-form") as HTMLFormElement;
    const btn = document.getElementById("submit-btn") as HTMLButtonElement;
    const status = document.getElementById(
        "form-status",
    ) as HTMLParagraphElement;

    form.addEventListener("submit", async (e) => {
        e.preventDefault();
        btn.disabled = true;
        btn.textContent = "Sending…";
        status.textContent = "";

        const data = new FormData(form);

        try {
            const res = await fetch("/api/contact", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    name: data.get("name"),
                    email: data.get("email"),
                    message: data.get("message"),
                    website: data.get("website"),
                }),
            });

            const json = await res.json();

            if (res.ok) {
                form.reset();
                status.textContent = "Message sent! I'll get back to you soon.";
                status.className = "text-sm text-violet-300";
            } else {
                status.textContent =
                    json.error ?? "Something went wrong. Please try again.";
                status.className = "text-sm text-red-400";
            }
        } catch {
            status.textContent = "Something went wrong. Please try again.";
            status.className = "text-sm text-red-400";
        } finally {
            btn.disabled = false;
            btn.textContent = "Send message";
        }
    });
</script>
